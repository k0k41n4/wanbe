---
import MainLayout from '../../layouts/MainLayout.astro';
import Ads from '../../components/Ads.astro';
import { getCollection } from 'astro:content';

// 1. Fungsi sakti buat ngasih tau Astro halaman apa aja yang mau dibuat
export async function getStaticPaths() {
  const allPosts = await getCollection('blog');
  
  // Ambil semua tag unik dari post lo
  const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags).flat())];

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.data.tags.includes(tag));
    return {
      params: { tag }, // Ini yang nentuin URL-nya (misal: /tags/living)
      props: { posts: filteredPosts }, // Data artikel yang dikirim ke halaman itu
    };
  });
}

const { tag } = Astro.params;
const { posts } = Astro.props;

// Formatting judul buat SEO
const displayTag = tag.charAt(0).toUpperCase() + tag.slice(1);
---

<MainLayout title={`${displayTag} — Wanbe Collection`}>
  <main class="container mx-auto max-w-4xl">
    
    <header class="mb-20">
      <div class="text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-4 italic font-serif">
        Browsing Category
      </div>
      <h1 class="text-6xl font-black tracking-tighter uppercase text-black">
        {tag}<span class="text-gray-200">.</span>
      </h1>
    </header>

    <div class="space-y-16">
      {posts.map((post) => (
        <article class="group border-b border-gray-50 pb-12">
          <a href={`/blog/${post.slug}`} class="block">
            <h2 class="text-2xl font-bold tracking-tight group-hover:text-gray-500 transition-colors uppercase mb-3">
              {post.data.title}
            </h2>
            <p class="text-gray-500 font-serif italic leading-relaxed mb-4 line-clamp-2">
              {post.data.description}
            </p>
            <span class="text-[10px] font-black uppercase tracking-widest text-black underline underline-offset-4 decoration-gray-200 group-hover:decoration-black transition-all">
              Read Story →
            </span>
          </a>
        </article>
      ))}
    </div>

    <Ads />

  </main>
</MainLayout>